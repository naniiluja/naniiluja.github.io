---
// Trang liệt kê mọi tag → link tới trang lọc theo tag.
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { extractUniqueTags } from '../../lib/tags';

// Chỉ tính tag từ bài đã publish.
const published = (await getCollection('blog')).filter((p) => !p.data.draft);
const tags = extractUniqueTags(published);
---

<BaseLayout title="Thẻ — naniiluja" description="Tất cả các thẻ trên naniiluja.">
  <h1 class="text-3xl font-bold">tags</h1>
  <ul class="mt-8 flex flex-wrap gap-3">
    {
      tags.map((tag) => (
        <li>
          <a
            href={`/tags/${encodeURIComponent(tag)}/`}
            class="rounded-full bg-slate-100 px-3 py-1 text-sm text-slate-700 hover:bg-slate-200 dark:bg-slate-800 dark:text-slate-300"
          >
            #{tag}
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
