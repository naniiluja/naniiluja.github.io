---
// Một dòng trong danh sách bài: link title + ngày.
import { formatDate } from '../lib/format-date';
import { postSlug } from '../lib/post-slug';

interface Props {
  id: string;
  title: string;
  date: Date;
}

const { id, title, date } = Astro.props;
const href = `/posts/${postSlug(id)}/`;
---

<li
  class="flex flex-col gap-1 border-b border-slate-100 py-3 dark:border-slate-800 sm:flex-row sm:items-baseline sm:justify-between"
>
  <a href={href} class="font-medium text-slate-900 hover:underline dark:text-slate-100">
    {title}
  </a>
  <time class="text-sm text-slate-500" datetime={date.toISOString()}>{formatDate(date)}</time>
</li>
