---
// Thanh điều hướng dùng chung. Liên kết tới trang chủ, About, Tags.
const links = [
  { href: '/', label: 'home' },
  { href: '/about', label: 'about' },
  { href: '/tags', label: 'tags' },
];
---

<nav class="mb-10 flex gap-4 border-b border-slate-100 pb-4 text-sm dark:border-slate-800">
  {
    links.map((link) => (
      <a
        href={link.href}
        class="text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100"
      >
        {link.label}
      </a>
    ))
  }
</nav>
