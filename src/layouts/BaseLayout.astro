---
// Layout chung: chứa <head> + meta SEO (canonical, OG, RSS alternate) + import global.css một lần.
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import { resolveOgImage } from '../lib/og-image';

interface Props {
  title: string;
  description?: string;
  /** OG type: 'website' cho trang thường, 'article' cho bài viết. */
  ogType?: 'website' | 'article';
  /** Ảnh share (OG image), path từ /public (vd '/claude-md.png'). Thiếu thì dùng ảnh mặc định. */
  image?: string;
}

const { title, description, ogType = 'website', image } = Astro.props;

// Canonical + RSS alternate dựng từ Astro.site (cấu hình trong astro.config.mjs).
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const rssUrl = new URL('rss.xml', Astro.site);
// OG image PHẢI là URL tuyệt đối — Facebook/Threads/LinkedIn không nhận path tương đối.
// resolveOgImage (helper thuần, có test) lo fallback DEFAULT khi thiếu.
const ogImageUrl = new URL(resolveOgImage(image), Astro.site);
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Áp theme TRƯỚC khi render body để chống FOUC. is:inline để không bị bundle/defer.
         Mặc định tối: chỉ bỏ .dark khi đã lưu 'light'. try/catch vì localStorage có thể throw
         (chế độ riêng tư) — fallback tường minh về dark, không silent-catch rỗng. -->
    <script is:inline>
      try {
        document.documentElement.classList.toggle('dark', localStorage.theme !== 'light');
      } catch {
        document.documentElement.classList.add('dark');
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>

    <!-- SEO: canonical + RSS discovery -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="naniiluja" href={rssUrl} />

    <!-- Open Graph: Facebook / Instagram / Threads / LinkedIn đều đọc OG khi share. -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="naniiluja" />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter/X Card: dùng ảnh lớn khi share. twitter:image cũng cần URL tuyệt đối. -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- GoatCounter: analytics nhẹ, không cookie. Guard no_onload để KHÔNG đếm
         localhost/preview (chỉ chạy ở production github.io) — tránh bẩn số liệu bằng lượt dev. -->
    <script is:inline>
      // Chỉ bật khi đúng host production; nếu không thì bật no_onload để bỏ qua local/preview.
      if (window.location.hostname !== 'naniiluja.github.io') {
        window.goatcounter = { no_onload: true };
      }
    </script>
    <script
      is:inline
      data-goatcounter="https://naniiluja.goatcounter.com/count"
      async
      src="//gc.zgo.at/count.js"></script>
  </head>
  <body
    class="min-h-screen bg-white text-slate-900 antialiased dark:bg-slate-900 dark:text-slate-100"
  >
    <main class="mx-auto max-w-3xl px-4 py-10">
      <Nav />
      <slot />
    </main>
  </body>
</html>
